{
  "name": "ng-select2-component",
  "version": "0.0.0",
  "description": "An Angular select2 component.",
  "author": "York Yao, Célian Veyssière",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng build ng-select2-component --configuration production && cp *.md dist/ng-select2-component",
    "build:demo": "ng build ng-select2 --configuration production",
    "publish:lib": "cd dist/ng-select2-component && npm publish --access public",
    "test": "vitest run --config vitest.config.mts",
    "test:vitest": "vitest run --config vitest.config.mts",
    "test:vitest:coverage": "vitest run --config vitest.config.mts --coverage",
    "test:vitest:watch": "vitest --config vitest.config.mts",
    "lint": "ng lint ng-select2-component",
    "format": "npx prettier --write .",
    "e2e": "ng e2e",
    "reinstall": "npm run clean && npm i",
    "reinstall:all": "npm run clean && rm -f package-lock.json && npm i",
    "clean": "npm cache clean --force && rm -rf ./dist/ ./.angular/ ./node_modules/"
  },
  "private": false,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/cdk": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@ikilote/json2html": "0.5.0",
    "@jsverse/transloco": "^7.5.0",
    "bootstrap": "^5.3.3",
    "bowser": "2.11.0",
    "core-js": "^2.5.4",
    "graphemer": "^1.4.0",
    "highlight.js": "11.10.0",
    "ngx-highlightjs": "12.0.0",
    "ngx-infinite-scroll": ">=19.0.0",
    "rxjs": "^7.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular-devkit/build-angular": "19.0.0",
    "@angular-eslint/builder": "19.0.0",
    "@angular-eslint/eslint-plugin": "19.0.0",
    "@angular-eslint/eslint-plugin-template": "19.0.0",
    "@angular-eslint/schematics": "19.0.0",
    "@angular-eslint/template-parser": "19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@angular/language-service": "^19.0.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "8.9.5",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "latest",
    "eslint-plugin-jsdoc": "latest",
    "eslint-plugin-prefer-arrow": "latest",
    "eslint-plugin-prettier": "^4.2.1",
    "happy-dom": "^20.8.4",
    "jsdom": "^27.0.1",
    "ng-packagr": "^19.0.0",
    "prettier": "^3.4.1",
    "prettier-plugin-css-order": "^2.1.2",
    "ts-node": "~7.0.1",
    "tslib": "^2.3.0",
    "typescript": "~5.6.3",
    "vitest": "^4.1.0"
  }
}
